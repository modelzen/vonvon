# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# Electron build artifacts
out/
dist/
# Ignore CONTENTS of top-level build/ (not the dir itself) so we can
# re-include the icon sources referenced by electron-builder.yml.
# git won't descend into a fully-ignored dir, which would make !rules
# no-ops — see the gitignore manpage.
/build/*
!/build/icon.icns
!/build/icon.svg
# Nested build/ dirs (submodules / hermes-agent) — list explicitly so
# the /build/* pattern above doesn't leak into them.
backend/hermes-agent/build/
*.app/

# electron-builder packaging staging + output
.dist/
release/

# TypeScript incremental build cache
*.tsbuildinfo

# Native build
native/build/
native/Release/
*.node

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Python
backend/.venv/
backend/__pycache__/
backend/.pytest_cache/
**/__pycache__/
*.py[cod]
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment
.env
.env.local

# OMC state (transient runtime data) — match at any depth, including backend/.omc/
**/.omc/state/
**/.omc/sessions/
**/.omc/handoffs/
**/.omc/checkpoints/
**/.omc/project-memory.json
**/.omc/subagent-tracking.json
**/.omc/agent-replay-*.jsonl

# Agent runtime
.agents/
/.claude/
/.omc/
skills-lock.json
